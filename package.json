{
  "name": "sv-axi",
  "version": "0.0.1",
  "description": "AXI CLI for inspecting SvelteKit projects, built for agents to drive via shell.",
  "type": "module",
  "bin": {
    "sv-axi": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "gen:docs": "node scripts/gen-docs-index.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "release": "node scripts/release.mjs",
    "test": "npm run build && node --test test/*.test.js"
  },
  "keywords": [
    "sveltekit",
    "svelte",
    "axi",
    "agent",
    "cli",
    "toon"
  ],
  "license": "MIT",
  "dependencies": {
    "@toon-format/toon": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
